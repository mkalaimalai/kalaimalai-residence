# Frontend env (Next.js). Copy to .env.local for local dev.
# With NONE of these set, the site builds from the local seed in data/ (current behavior).

# Source public pages from the live API at build time instead of the seed.
# Set DATA_SOURCE=api to enable; leave unset for seed.
DATA_SOURCE=
API_BASE_URL=http://localhost:8099
# Fall back to the local seed if the API is unreachable at build (keeps CI green).
ALLOW_SEED_FALLBACK=1

# Public values inlined into the browser bundle (portal live data + Supabase auth).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8099
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
