# Backend env (FastAPI). Copy to api/.env for local dev, or set in Render.

# Supabase Postgres. Use the POOLED connection string (port 6543) on Render.
# Local dev example points at a local Postgres.
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/postgres

# Supabase project JWT secret — verifies portal access tokens (Project Settings → API).
SUPABASE_JWT_SECRET=change-me
SUPABASE_JWT_AUDIENCE=authenticated

# Comma-separated browser origins allowed by CORS (the GitHub Pages site + local dev).
CORS_ORIGINS=https://mkalaimalai-residence.github.io,http://localhost:3000

# Local-only convenience: disable auth so seeding/manual testing needs no token.
# MUST be false (or unset) in production.
AUTH_DISABLED=false
