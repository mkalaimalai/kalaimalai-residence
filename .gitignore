# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!api/.env.example

# python backend (api/)
api/.venv/
**/__pycache__/
*.pyc
# generated seed bridge — regenerate with `npm run export:seed`
api/scripts/seed.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Source design assets — kept local, not published
artifacts/

# Internal business strategy — keep local, do not publish on the public repo
docs/business-brainstorm.html
